DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=recipe_db

# sqlite 範例（本地開發用）
# DATABASE_URL=sqlite:///./recipe_app.db

# mysql 範例
# DATABASE_URL=mysql+aiomysql://root:password@localhost/recipe_db

# postgresql 範例
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/recipe_db

APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
